# ─── Monday.com ───────────────────────────────────────────────
MONDAY_API_TOKEN=your_monday_api_token_here
MONDAY_BOARD_ID=6533700776

# Confirmed column IDs — Manufacturing Process board
MONDAY_COL_CUSTOMER_EMAIL=email__1
MONDAY_COL_STATUS=status__1
MONDAY_COL_TRACKING_NUMBER=lookup_mm1kcbb5
MONDAY_COL_FREIGHT_TRACKING=dup__of_gb_production7__1
MONDAY_COL_PORTAL_FILES=file_mm4wbdrh
MONDAY_COL_INVOICE_LINK=text_mm4wfamc
MONDAY_COL_SHIP_DATE=date_mkvvpex1
MONDAY_COL_ADDRESS=long_text_mkpkdtj4
MONDAY_COL_PRODUCT_TYPE=color_mkvw7b8

# Tax exemption — Invoice & Payment tab (Yes/No selector + certificate upload)
MONDAY_COL_TAX_EXEMPT_STATUS=color_mm55tjn2
MONDAY_COL_TAX_EXEMPT_CERT=file_mm55t6kn
# Only needed if the "Tax Exempt?" status column's labels aren't exactly "Yes"/"No"
MONDAY_TAX_EXEMPT_YES_LABEL=Yes
MONDAY_TAX_EXEMPT_NO_LABEL=No

# Manufacturing Phase status labels (must match exactly what's in Monday.com)
MONDAY_STATUS_ORDER_PLACED=Order Placed
MONDAY_STATUS_DEPOSIT_RECEIVED=Deposit Received
MONDAY_STATUS_IN_MANUFACTURING=In Manufacturing
MONDAY_STATUS_READY_TO_SHIP=Ready to Ship
MONDAY_STATUS_SHIPPED=Shipped
MONDAY_STATUS_DELIVERED=Delivered

# ─── Authentication ────────────────────────────────────────────
NEXTAUTH_URL=https://portal.summitsensory.com
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Microsoft 365 SSO (for staff login)
AZURE_AD_CLIENT_ID=your_azure_app_client_id
AZURE_AD_CLIENT_SECRET=your_azure_app_client_secret
AZURE_AD_TENANT_ID=your_azure_tenant_id
STAFF_EMAIL_DOMAIN=summitsensorygym.com

# ─── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=portal@updates.summitsensory.com
EMAIL_FROM_NAME=Summit Sensory Gym
NOTIFY_TEAM_EMAIL=orders@summitsensorygym.com

# ─── FedEx ────────────────────────────────────────────────────
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
FEDEX_ACCOUNT_NUMBER=

# ─── AfterShip (carrier-agnostic tracking) ────────────────────
# Create at: organization.automizely.com/api-keys
# Sent as the "as-api-key" request header. Never commit the real value.
AFTERSHIP_API_KEY=
# Optional: secret used to verify inbound AfterShip status webhooks
AFTERSHIP_WEBHOOK_SECRET=

# ─── Cron security ────────────────────────────────────────────
# Random secret — Vercel passes this in the Authorization header to /api/cron/*
# Generate: openssl rand -base64 32
CRON_SECRET=generate_with_openssl_rand_base64_32

# ─── Cron reminder settings ────────────────────────────────────
REMINDER_INTERVAL_DAYS=3
REMINDER_MAX_COUNT=6

# ─── Monday.com optional columns ──────────────────────────────
# Writable tracking number column (separate from read-only mirror)
MONDAY_COL_TRACKING_WRITE=
# Balance due column (number or currency type)
MONDAY_COL_BALANCE=
# Multi-shipment tracking
MONDAY_COL_MAT_TRACKING=
MONDAY_COL_OTHER_SHIPMENTS=
# Installation content
MONDAY_COL_INSTALLATION_VIDEOS=
MONDAY_COL_INSTALLATION_DOCS=
MONDAY_COL_INSTALLATION_LINKS=text_mm4x6xvf
# Payment portal link
MONDAY_COL_PAYMENT_LINK=

# ─── Email ─────────────────────────────────────────────────────
# Optional: override the logo URL used in emails
# Defaults to https://portal.summitsensory.com/ssg-logo.png
EMAIL_LOGO_URL=

# ─── Jotform ──────────────────────────────────────────────────
JOTFORM_WEBHOOK_SECRET=
# Overrides the Monday.com mirror column for the color selection form embed.
# Set to the numeric Jotform form ID (e.g. 243436740186156).
JOTFORM_COLOR_FORM_ID=

# Product-to-form mapping. Format:
# { "formId": { "name": "...", "description": "...", "tab": "color|required_documents", "productTypes": ["..."] } }
# Omit productTypes to apply to all products.
# Therapy Mats & Padding color form TBD — add when available.
JOTFORM_FORM_MAP={"243444705854057":{"name":"Pickup & Delivery Form","description":"Confirms your pickup and delivery preferences","tab":"required_documents"},"243436740186156":{"name":"Color Selection","description":"Select your equipment colors","tab":"color_selection","productTypes":["Summit Adventure Series"]},"243396895100057":{"name":"Color Selection","description":"Select your equipment colors","tab":"color_selection","productTypes":["Summit Soar"]},"243426572564158":{"name":"Color Selection","description":"Select your equipment colors","tab":"color_selection","productTypes":["Summit Flex"]}}
